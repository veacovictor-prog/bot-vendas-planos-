DISCORD_TOKEN=cole_o_token_do_bot_aqui
CLIENT_ID=id_da_aplicacao_do_bot
GUILD_ID=id_do_servidor

# Canal onde o bot registra vendas e aprovacoes
LOG_CHANNEL_ID=

# Categoria onde os tickets de compra serao criados
TICKET_CATEGORY_ID=

# Cargo que pode aprovar/reprovar pedidos
STAFF_ROLE_ID=

# Chave Pix exibida no ticket de pagamento
PIX_KEY=sua_chave_pix_aqui

# Nome da sua loja
STORE_NAME=Minha Loja de Bots

# Link do seu servidor/suporte, se tiver
SUPPORT_URL=https://discord.gg/seuconvite

# Opcional no Railway: use /data se criar um Volume montado nesse caminho
DATA_DIR=./data

# Railway define PORT automaticamente. Localmente pode deixar vazio.
PORT=
